# HSM Management System - Environment Variables
# Copy this file to .env and update with your values

# ==================== DATABASE ====================

# Option 1: Use connection string (for Neon, Supabase, Railway, etc.)
# Uncomment and set your connection string:
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Option 2: Use individual parameters (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hsm_dev
DB_USER=hsm_admin
DB_PASSWORD=secret

# ==================== SERVER ====================

PORT=3000
NODE_ENV=development

# ==================== CORS ====================

# Comma-separated list of allowed origins for CORS
# For development: http://localhost:5173
# For production: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# ==================== OLLAMA (Optional - for AI features) ====================

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# ==================== EMAIL ====================

# Gmail account used as the sender for all system emails
# Use a Gmail App Password (not your regular password):
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# ==================== PAYOUT REPORT SCHEDULER ====================

# Comma-separated list of email addresses to receive the monthly payout report
# Sent automatically at 09:00 on the 25th of every month
PAYOUT_REPORT_RECIPIENTS=finance@hsm.com,admin@hsm.com

# Override the cron schedule (default: 25th of month at 09:00)
# Format: "minute hour day-of-month month day-of-week"
# PAYOUT_CRON_SCHEDULE=0 9 25 * *

# ==================== GOOGLE PLACES (Reviews on Landing Page) ====================

# Used to fetch real Google reviews for the landing page testimonials section.
# 1. Go to console.cloud.google.com → Enable "Places API"
# 2. Create an API key (restrict it to your server IP for production)
# 3. Find your Place ID at: https://developers.google.com/maps/documentation/places/web-service/place-id
#    (Search for "Hyderabad School of Music" and copy the Place ID)
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_PLACE_ID=ChIJ...your-place-id

# ==================== GOOGLE OAUTH ====================

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Callback URL registered in Google Cloud Console → OAuth 2.0 → Authorized redirect URIs
# Dev default (desktop browser): http://localhost:3000/api/auth/google/callback
# For mobile testing (USB debugging): use port 5173 so Google redirects via Vite proxy
#   GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
#   Also add http://localhost:5173/api/auth/google/callback to Google Console redirect URIs
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend URL — where to redirect after successful OAuth
# Dev default: http://localhost:5173
# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ==================== WHATSAPP CLOUD API ====================

# Meta WhatsApp Cloud API credentials (https://developers.facebook.com/apps)
# Leave blank to disable WhatsApp notifications entirely (safe — all calls are no-ops)
#
# 1. Create a Meta App → Add WhatsApp product
# 2. WHATSAPP_API_TOKEN: System User token (not the temporary test token)
# 3. WHATSAPP_PHONE_NUMBER_ID: Found in WhatsApp → API Setup
# 4. WHATSAPP_BUSINESS_ACCOUNT_ID: Found in WhatsApp → API Setup (WABA ID)
# 5. WHATSAPP_WEBHOOK_SECRET: Any random string — set the same value in Meta webhook config
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_SECRET=

# ==================== NOTES ====================

# For Neon (neon.tech):
# - Get connection string from: Dashboard → Connection Details
# - Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# - Set DATABASE_URL and comment out individual DB_* variables

# For local Docker:
# - Keep DB_* variables as is
# - DATABASE_URL should be commented out
