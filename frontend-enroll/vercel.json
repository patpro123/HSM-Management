{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/intake", "destination": "/intake.html" },
    { "source": "/demoday", "destination": "/demoday.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
